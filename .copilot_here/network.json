{
  "enabled": true,
  "enable_logging": true,
  "inherit_default_rules": true,
  "mode": "enforce",
  "allowed_rules": [
    {
      "host": "api.nuget.org",
      "allowed_paths": [
        "/v3/*",
        "/v3-index/*",
        "/v3-flatcontainer/*"
      ]
    },
    {
      "host": "index.crates.io",
      "allowed_paths": [
        "*"
      ]
    },
    {
      "host": "static.crates.io",
      "allowed_paths": [
        "*"
      ]
    },
    {
      "host": "crates.io",
      "allowed_paths": [
        "*"
      ]
    }
  ]
}